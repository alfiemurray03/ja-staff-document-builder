# JA Staff Document Builder - unauthenticated development configuration
VITE_APP_NAME=JA Staff Document Builder
VITE_PUBLIC_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173/api
NODE_ENV=development
HOST=127.0.0.1
PORT=5173

# Temporary staff profile (convenience only; not a security control)
VITE_STAFF_DISPLAY_NAME=Development Staff User
VITE_STAFF_JOB_TITLE=Staff Member
VITE_STAFF_COMPANY=JA Group Services Ltd
VITE_STAFF_DEPARTMENT=Operations
VITE_STAFF_EMAIL=staff@example.invalid
INTERNAL_STAFF_OWNER_ID=1

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ja_document_builder
DB_PASS=replace-with-local-development-password
DB_NAME=ja_staff_document_builder
